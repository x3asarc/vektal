{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Task(*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/start-health-daemon.py"
          },
          {
            "type": "command",
            "command": "python scripts/memory/session_start.py"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-check-update.js"
          },
          {
            "type": "command",
            "command": "python .claude/hooks/check-pending-improvements.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "filter": {
          "tool": "Bash"
        },
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/governance/health_gate.py",
            "blockOnFailure": false
          },
          {
            "type": "command",
            "command": "python scripts/memory/pre_tool_update.py --provider claude --session-key claude-pretool --window-hint claude",
            "blockOnFailure": false
          }
        ]
      },
      {
        "filter": {
          "tool": "Bash",
          "commandPattern": "git commit.*"
        },
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/governance/risk_tier_gate_enforce.py",
            "blockOnFailure": true
          }
        ]
      },
      {
        "filter": {
          "tool": "Task"
        },
        "hooks": []
      },
      {
        "filter": {
          "tool": "Edit"
        },
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/hooks/graph_impact_advisor.py",
            "blockOnFailure": false
          }
        ]
      },
      {
        "filter": {
          "tool": "Write"
        },
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/hooks/graph_impact_advisor.py",
            "blockOnFailure": false
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "filter": {
          "tool": "Edit"
        },
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/hooks/test_recommender.py",
            "blockOnFailure": false
          }
        ]
      },
      {
        "filter": {
          "tool": "Write"
        },
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/hooks/test_recommender.py",
            "blockOnFailure": false
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/hooks/gsd-statusline.js"
  }
}
