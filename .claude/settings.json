{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-check-update.js"
          },
          {
            "type": "command",
            "command": "python .claude/hooks/check-pending-improvements.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "filter": {
          "tool": "Bash"
        },
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/governance/ensure_neo4j_runtime.py",
            "blockOnFailure": true
          }
        ]
      },
      {
        "filter": {
          "tool": "Bash",
          "commandPattern": "git commit.*"
        },
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/governance/risk_tier_gate_enforce.py",
            "blockOnFailure": true
          }
        ]
      }
    ],
    "PostToolUse": []
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/hooks/gsd-statusline.js"
  }
}
