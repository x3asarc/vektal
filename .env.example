# ===========================================
# Shopify Multi-Supplier Platform - Environment Variables
# ===========================================
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control

# -------------------------------------------
# Shopify App Credentials (from Partners Dashboard)
# Get these from: https://partners.shopify.com/
# -------------------------------------------
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# -------------------------------------------
# Flask Configuration
# -------------------------------------------
FLASK_SECRET_KEY=change-this-to-a-random-secret-key-in-production
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_APP=src/app.py
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# -------------------------------------------
# Observability (Sentry)
# -------------------------------------------
# Flask API project DSN (python-flask)
SENTRY_DSN=
# Celery workers project DSN (synthex-workers)
SENTRY_WORKERS_DSN=
# Frontend project DSN (synthex-frontend)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_SEND_DEFAULT_PII=true
SENTRY_ENABLE_LOGS=true
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0
SENTRY_WORKERS_TRACES_SAMPLE_RATE=1.0
SENTRY_WORKERS_PROFILES_SAMPLE_RATE=1.0
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Encryption key for OAuth tokens (generate with: python -c "from src.core.encryption import generate_encryption_key; print(generate_encryption_key())")
ENCRYPTION_KEY=generate_a_key_using_the_command_above

# Shopify API Version
API_VERSION=2024-01

# Legacy Client Credentials (for backward compatibility)
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here
SHOP_DOMAIN=your-store.myshopify.com

# -------------------------------------------
# AI Services (You pay, users don't)
# -------------------------------------------
# Gemini AI (SEO content generation)
GEMINI_API_KEY=your_gemini_key_here
SEO_MODEL_ID=gemini-2.0-flash-exp

# Vision AI (alt text generation via OpenRouter)
OPENROUTER_API_KEY=your_openrouter_key_here
PERPLEXITY_API_KEY=your_perplexity_key_here
VISION_AI_PROVIDER=openrouter
VISION_AI_MODEL=google/gemini-flash-1.5-8b
VISION_AI_MAX_RETRIES=3
VISION_AI_CACHE_DB=data/vision_cache.db
VISION_AI_DAILY_BUDGET_EUR=1.0
VISION_AI_MONTHLY_BUDGET_EUR=30.0

# -------------------------------------------
# Docker Services Configuration
# -------------------------------------------
# PostgreSQL Database
DB_PASSWORD=changeme_strong_password_here
DB_USER=admin
DB_NAME=shopify_platform
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}

# Redis (Celery broker and cache)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Redis Connection Resilience (Sentry #101522185, #101522288)
# Prevents zombie workers when Redis is temporarily unavailable
REDIS_KEEPALIVE_IDLE=60
REDIS_KEEPALIVE_INTERVAL=10
REDIS_KEEPALIVE_COUNT=3

# -------------------------------------------
# Service Ports (Development - all exposed for debugging)
# -------------------------------------------
# Primary access: http://localhost (Nginx)
# Debug access:
#   - Flask API: http://localhost:5000
#   - Next.js: http://localhost:3000
#   - PostgreSQL: localhost:5432
#   - Redis: localhost:6379
#   - Neo4j Browser: http://localhost:7474
NGINX_PORT=80
FLASK_PORT=5000
NEXTJS_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379

# -------------------------------------------
# Neo4j Graph Database (Phase 13.2 - Temporal Knowledge Storage)
# -------------------------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeit
GRAPH_ORACLE_ENABLED=true

# -------------------------------------------
# Neo4j Aura (Cloud - Phase 14.3)
# Optional: For production cloud deployment
# Get credentials from: https://console.neo4j.io/
# -------------------------------------------
AURA_INSTANCE_ID=your_instance_id_here
AURA_TENANT_ID=your_tenant_id_here
AURA_CLIENT_ID=your_client_id_here
AURA_CLIENT_SECRET=your_client_secret_here

# -------------------------------------------
# Sentry Issue Management (Phase 14.3, 15)
# For autonomous failure triage and remediation
# Get from: https://sentry.io/settings/account/api/auth-tokens/
# -------------------------------------------
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
# Frontend sourcemap upload target (Next.js build)
SENTRY_ORG=x3-solutions
SENTRY_PROJECT=synthex-frontend
# API issue-poller target
SENTRY_ORG_SLUG=x3-solutions
SENTRY_PROJECT_SLUG=python-flask

# -------------------------------------------
# Phase 15: Self-Healing & Autonomous Remediation
# -------------------------------------------
# Sandbox Configuration
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT_SECONDS=300
SANDBOX_MAX_FILES=5
SANDBOX_MAX_LOC=500

# Autonomous Remediation
AUTO_APPLY_CONFIDENCE_THRESHOLD=0.9
AUTO_APPROVE_INFRASTRUCTURE=true
AUTO_APPROVE_CODE=false

# Template Learning
TEMPLATE_PROMOTION_THRESHOLD=2
TEMPLATE_CONFIDENCE_THRESHOLD=0.8
TEMPLATE_TTL_DAYS=90

# LLM for Remediation (adaptive routing)
REMEDIATION_LLM_PROVIDER=openrouter
REMEDIATION_LLM_MODEL=anthropic/claude-sonnet-4.5
REMEDIATION_LLM_FALLBACK=google/gemini-flash-1.5

# Connection Pool Auto-Tuning
POOL_TUNING_ENABLED=true
POOL_MIN_SIZE=3
POOL_MAX_SIZE=20
POOL_TUNING_INTERVAL_HOURS=1
