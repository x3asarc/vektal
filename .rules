canonical_roadmap=.planning/ROADMAP.md
canonical_state=.planning/STATE.md
require_task_report_count=4
require_task_report_files=self-check.md,review.md,structure-audit.md,integrity-audit.md
require_no_empty_required_fields=true
allow_non_applicable_literal=N/A
require_review_field=pass_1_timestamp
require_review_field=pass_2_timestamp
require_review_field=plan_context_opened_at
require_blind_review_ordering=true
merge_block_on=Critical
merge_block_on=High
merge_block_on=Medium:Security
merge_block_on=Medium:Dependency
kiss_target_loc_min=150
kiss_target_loc_max=400
kiss_warning_loc_threshold=500
kiss_exception_loc_threshold=800
kiss_exception_requires=architecture_note_with_refactoring_plan
require_followup_decomposition_for_loc_gte_800=true
require_tool_version_pinning=requirements.txt|package-lock.json
require_tool_execution=lint,scan,test
dependency_policy=default_deny_unknown_package
dependency_policy=known_good_autoapprove_if_age_gt_2y_and_weekly_downloads_gt_1000000
license_policy=block_strong_copyleft
license_policy=allow_permissive_default
protected_path=.planning
protected_path=.rules
protected_path=AGENTS.md
structure_guardian_auto_move_disallowed_on_protected_paths=true

