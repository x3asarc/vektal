        "info": "{colors.primitives.brand.500}"
      },
      "states": {
        "hover_overlay": "rgba(40, 85, 140, 0.06)",
        "active_overlay": "rgba(40, 85, 140, 0.1)",
        "focus_ring": "{colors.primitives.brand.400}",
        "disabled_opacity": "0.48"
      },
      "contrast_targets": {
        "body_text_min": "4.5:1",
        "large_text_min": "3:1",
        "non_text_ui_min": "3:1"
      }
    },
    "typography": {
      "families": {
        "display": "\"Segoe UI\", \"SF Pro Display\", sans-serif",
        "body": "\"Segoe UI\", \"SF Pro Text\", sans-serif",
        "mono": "\"Cascadia Code\", \"JetBrains Mono\", monospace"
      },
      "weights": {
        "regular": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700
      },
      "size_scale": {
        "2xs": "0.6875rem",
        "xs": "0.75rem",
        "sm": "0.8125rem",
        "md": "0.875rem",
        "lg": "1rem",
        "xl": "1.125rem",
        "2xl": "1.25rem",
        "3xl": "1.5rem",
        "4xl": "1.875rem",
        "5xl": "2.25rem"
      },
      "line_height_scale": {
        "tight": 1.2,
        "snug": 1.35,
        "normal": 1.5,
        "relaxed": 1.625
      },
      "letter_spacing_scale": {
        "tighter": "-0.01em",
        "tight": "-0.005em",
        "normal": "0em",
        "wide": "0.01em",
        "wider": "0.02em"
      },
      "role_map": {
        "h1": {
          "family": "display",
          "size": "3xl",
          "weight": "semibold",
          "line_height": "tight",
          "letter_spacing": "tight"
        },
        "h2": {
          "family": "display",
          "size": "2xl",
          "weight": "semibold",
          "line_height": "snug",
          "letter_spacing": "tight"
        },
        "body": {
          "family": "body",
          "size": "md",
          "weight": "regular",
          "line_height": "normal",
          "letter_spacing": "normal"
        },
        "caption": {
          "family": "body",
          "size": "xs",
          "weight": "regular",
          "line_height": "normal",
          "letter_spacing": "wide"
        },
        "code": {
          "family": "mono",
          "size": "sm",
          "weight": "regular",
          "line_height": "normal",
          "letter_spacing": "normal"
        }
      }
    },
    "spacing": {
      "base_unit": "4px",
      "scale": {
        "0": "0",
        "1": "0.25rem",
        "2": "0.5rem",
        "3": "0.75rem",
        "4": "1rem",
        "5": "1.25rem",
        "6": "1.5rem",
        "8": "2rem",
        "10": "2.5rem",
        "12": "3rem",
        "16": "4rem"
      },
      "layout": {
        "container_max": "100%",
        "section_padding_y": "0.75rem",
        "section_padding_x": "0.75rem",
        "grid_gap": "0.75rem"
      }
    },
    "radius": {
      "scale": {
        "none": "0",
        "xs": "0.125rem",
        "sm": "0.25rem",
        "md": "0.375rem",
        "lg": "0.5rem",
        "xl": "0.75rem",
        "2xl": "1rem",
        "pill": "9999px"
      },
      "component_map": {
        "button": "sm",
        "card": "md",
        "input": "sm",
        "chip": "pill",
        "modal": "lg",
        "panel": "md"
      },
      "border_width": {
        "hairline": "1px",
        "default": "1px",
        "strong": "2px"
      }
    },
    "motion": {
      "duration": {
        "instant": "0ms",
        "fast": "120ms",
        "base": "180ms",
        "slow": "280ms",
        "slower": "420ms"
      },
      "easing": {
        "standard": "cubic-bezier(0.2, 0, 0, 1)",
        "emphasized": "cubic-bezier(0.2, 0.8, 0.2, 1)",
        "entrance": "cubic-bezier(0.16, 1, 0.3, 1)",
        "exit": "cubic-bezier(0.7, 0, 0.84, 0)"
      },
      "presets": {
        "hover": "background-color var(--motion-duration-fast) var(--motion-easing-standard), border-color var(--motion-duration-fast) var(--motion-easing-standard)",
        "focus": "outline-color var(--motion-duration-fast) var(--motion-easing-standard)",
        "panel_resize": "width var(--motion-duration-base) var(--motion-easing-standard), height var(--motion-duration-base) var(--motion-easing-standard)"
      },
      "keyframes": {
        "fade_in": {
          "from": {
            "opacity": 0
          },
          "to": {
            "opacity": 1
          }
        }
      },
      "reduced_motion": {
        "enabled": true,
        "strategy": "Disable panel/position transitions and keep only instant state updates."
      }
    },
    "effects": {
      "shadows": {
        "sm": "0 1px 2px rgba(17, 24, 39, 0.06)",
        "md": "0 8px 20px rgba(17, 24, 39, 0.08)",
        "lg": "0 16px 36px rgba(17, 24, 39, 0.1)"
      },
      "blur": {
        "glass": "8px",
        "backdrop": "12px"
      },
      "opacity": {
        "muted": "0.64",
        "overlay": "0.1",
        "disabled": "0.45"
      }
    }
  },
  "patterns": {
    "layout_type": "ide-workbench|split-pane|dense-grid",
    "component_blueprints": [
      {
        "name": "ExplorerSidebar",
        "visual_notes": "Narrow left navigation with dense row spacing and subtle separators.",
        "states": ["default", "hover", "active", "focus-visible", "disabled"]
      },
      {
        "name": "EditorPane",
        "visual_notes": "White editor surfaces with low-radius containers and code-heavy typography.",
        "states": ["default", "focus-visible"]
      },
      {
        "name": "TabbedPanels",
        "visual_notes": "Multiple split panes with compact headers and thin borders.",
        "states": ["default", "active", "focus-visible"]
      }
    ]
  },
  "implementation_hints": {
    "css_variables_output": true,
    "tailwind_theme_mapping": true,
    "notes": "Optimized for high-density productivity UI. Prefer compact spacing and restrained motion."
  }
}
