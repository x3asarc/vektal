{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .codex/hooks/start-health-daemon.py"
          },
          {
            "type": "command",
            "command": "python scripts/memory/session_start.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "filter": {
          "tool": "Bash"
        },
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/governance/health_gate.py",
            "blockOnFailure": false
          },
          {
            "type": "command",
            "command": "python scripts/memory/pre_tool_update.py --provider codex --session-key codex-pretool --window-hint codex",
            "blockOnFailure": false
          },
          {
            "type": "command",
            "command": "python scripts/hooks/antigravity_notify.py --provider codex --source pre_tool_use --heartbeat --window-hint codex",
            "blockOnFailure": false
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "stitch": {
      "command": "./venv/Scripts/python.exe",
      "args": [
        "scripts/mcp/start_stitch_mcp.py"
      ]
    },
    "synthex-knowledge-graph": {
      "command": "./venv/Scripts/python.exe",
      "args": [
        "src/graph/mcp_server.py"
      ]
    }
  }
}
