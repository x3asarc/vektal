# =============================================================================
# Shopify Multi-Supplier Platform — .gitignore
# =============================================================================

# --- Secrets & environment (NEVER commit) ---
.env
.env.local
.env.*.local
*.key
*.pem
*.p12
*.pfx
secrets/
.secrets/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.tox/
.venv/
venv/
env/
.Python
pip-log.txt
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.cover
.hypothesis/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# --- Node / Next.js ---
node_modules/
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
frontend/tsconfig.tsbuildinfo
.npm

# --- Playwright / test artifacts ---
test-results/
playwright-report/
*.trace.zip

# --- Logs ---
logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*

# --- Docker ---
docker-compose.override.yml

# --- Database / data (potentially large or sensitive) ---
*.sqlite
*.sqlite3
*.db
data/
results/

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Windows artifacts ---
desktop.ini
nul

# --- Broken pip fragments found in root ---
=3.1.0
=4.0.0
=42.0.0

# --- Screenshots / binary media (use test-results/ for evidence) ---
"Screenshot *.png"
reports/meta/*.png
reports/meta/*.json

# --- Playwright evidence (committed only when promoting to CI artifacts) ---
test-results/

# --- Project-specific large/external dirs not part of the platform ---
awesome-claude-code/
codexclaude/
quickcleanup/
side-project/
universal_vendor_scraper/
.minimax/
.agents/

# --- Personal notes / scratch docs (not platform code) ---
precisionworkspace.md
productionagents.md
skillbuilding.md
solutionsarchitect.md
codex.md
screenshots/

# --- One-off setup scripts (not platform code) ---
install-scoop.ps1
INSTALL_SCOOP.md
stripe-webhook-local.bat
test-stripe-webhooks.bat
setup-stripe-webhooks.bat
STRIPE_WEBHOOK_SETUP.md

# --- Temp dirs ---
temp/

# --- Screenshots in root ---
*.png

# --- Archive backups ---
archive/image_scraper_backup_*.py
