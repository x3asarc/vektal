# =============================================================================
# Shopify Multi-Supplier Platform — .gitignore
# Last reviewed: 2026-03-09
# =============================================================================

# --- Secrets & environment (NEVER commit) ---
.env
.env.local
.env.*.local
*.key
*.pem
*.p12
*.pfx
secrets/
.secrets/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.tox/
.venv/
venv/
env/
.Python
pip-log.txt
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.cover
.hypothesis/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
requirements-dev.txt
torchinductor_Hp/

# --- Node / Next.js ---
node_modules/
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
frontend/tsconfig.tsbuildinfo
.npm

# --- Playwright / test artifacts ---
test-results/
playwright-report/
*.trace.zip

# --- Logs ---
logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*

# --- Docker ---
docker-compose.override.yml

# --- Database / data (potentially large or sensitive) ---
*.sqlite
*.sqlite3
*.db
data/
results/

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Windows artifacts ---
desktop.ini
nul
C
torchinductor_Hp/
go1.21.0.linux-amd64.tar.gz

# --- Broken pip install fragments in root (junk files — delete them too) ---
=3.1.0
=4.0.0
=42.0.0

# --- Screenshots / binary media (use test-results/ for evidence) ---
"Screenshot *.png"
reports/meta/*.png
reports/meta/*.json

# --- Playwright evidence (committed only when promoting to CI artifacts) ---
test-results/

# --- Project-specific large/external dirs not part of the platform ---
awesome-claude-code/
codexclaude/
quickcleanup/
side-project/
universal_vendor_scraper/
.minimax/
# NOTE: .agents/ is now TRACKED (removed from gitignore 2026-03-09)
# Reason: multi-PC workflow — git pull on any machine gives full skill/oracle setup
# .agents/skills/ is the canonical cross-platform skill location
# Platform mirrors (.claude/, .codex/, .gemini/) stay for platform-specific entry points

# --- Personal notes / scratch docs (not platform code) ---
precisionworkspace.md
productionagents.md
skillbuilding.md
solutionsarchitect.md
codex.md
screenshots/

# --- One-off setup scripts (not platform code) ---
install-scoop.ps1
INSTALL_SCOOP.md
stripe-webhook-local.bat
test-stripe-webhooks.bat
setup-stripe-webhooks.bat
STRIPE_WEBHOOK_SETUP.md

# --- Temp dirs and scratch files ---
temp/
temp_*.py
.graph/
.firecrawl/
.tooling/external-tools-health.json
.tooling/firecrawl-smoke.json

# --- Screenshots in root ---
*.png

# --- Archive backups ---
archive/image_scraper_backup_*.py
.aider*

# --- OODA loop runtime artifacts (not platform code) ---
# .ooda/dashboard_obs.html and .ooda/dashboard_obs.txt are already tracked (keep them)
# All new .ooda/ files and frontend/.ooda/ are ignored going forward
.ooda/*.txt
.ooda/*.json
frontend/.ooda/

# --- Agent runtime / working memory (not platform code) ---
# .memory/long-term/ and .memory/events/ are tracked (platform intelligence)
# .memory/working/ is runtime session data — local only
.memory/working/
